# FinBot Configuration
# Copy this file to .env and customize as needed.

# Ollama
FINBOT_OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M
FINBOT_OLLAMA_HOST=http://127.0.0.1:11434

# Docker: uncomment to point at the Ollama container instead
# FINBOT_OLLAMA_HOST=http://ollama:11434

# Encryption key directory (default: ~/.finbot)
# Docker: set to a path inside the data volume so keys persist
# FINBOT_KEY_DIR=/app/data/.keys

# Session security
FINBOT_SESSION_TIMEOUT_MINUTES=15
FINBOT_REQUIRE_PIN=true

# Watch folder for auto-import
FINBOT_WATCH_FOLDER=~/finbot-inbox

# Projections
FINBOT_DEFAULT_INFLATION_RATE=0.03
FINBOT_REBALANCE_DRIFT_THRESHOLD=0.05

# Import file cleanup (days before deletion, 0 = never)
FINBOT_IMPORT_CLEANUP_DAYS=30

# Server port (default 8000)
# FINBOT_LAN_PORT=8000
